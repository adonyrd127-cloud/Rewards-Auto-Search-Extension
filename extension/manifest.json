{
  "manifest_version": 3,
  "name": "Rewards Auto Search & Claimer",
  "version": "3.1.0",
  "description": "Automatiza búsquedas de escritorio y Edge en Bing, resuelve quizzes/polls, y reclama tareas diarias en rewards.bing.com.",
  "permissions": [
    "storage",
    "declarativeNetRequest",
    "alarms",
    "tabs",
    "scripting",
    "notifications"
  ],
  "host_permissions": [
    "*://*.bing.com/*",
    "*://*.microsoft.com/*",
    "*://trends.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.bing.com/*",
        "*://rewards.bing.com/*"
      ],
      "js": [
        "spoof.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "*://rewards.bing.com/*",
        "*://*.bing.com/rewards/*"
      ],
      "js": [
        "utils/dom-utils.js",
        "utils/human-sim.js",
        "utils/retry.js",
        "workers/daily-set.js",
        "workers/more-activities.js",
        "workers/punch-cards.js",
        "workers/streak-bonus.js",
        "content.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "*://*.bing.com/search*"
      ],
      "js": [
        "utils/dom-utils.js",
        "utils/human-sim.js",
        "content.js"
      ],
      "run_at": "document_end"
    }
  ]
}
